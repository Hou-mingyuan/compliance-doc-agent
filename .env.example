# ======================================================================
# compliance-doc-agent 环境变量示例（草稿）
# 复制为 .env 后按需修改： cp .env.example .env
# 默认 Mock LLM，无需密钥即可体验规则引擎 + 合规分析流程。
# ======================================================================

# ---------------- 大模型 ----------------
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=90

# --- 接入真实大模型示例（OpenAI 兼容）---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-your-api-key-here

# ---------------- 数据库（Docker Compose 草稿）----------------
# 默认：内存 H2（容器重启后数据清空）
SPRING_DATASOURCE_URL=jdbc:h2:mem:compliance;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_DELAY=-1

# 可选：文件 H2 持久化（需 docker compose --profile h2-persist）
# SPRING_DATASOURCE_URL=jdbc:h2:file:/data/compliance;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_ON_EXIT=FALSE

SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# ---------------- Compose 模式 ----------------
# dev  = 后端 + Vite 热更新（默认）
# prod = 后端 + Nginx 静态前端（docker compose --profile prod up）
COMPOSE_PROFILES=dev

# ---------------- 服务端口（与 docker-compose 映射一致）----------------
# 开发（COMPOSE_PROFILES=dev）：后端 8080 + 前端 5173
BACKEND_HOST_PORT=8080
FRONTEND_PORT=5173

# 生产（docker compose --profile prod up）建议：
# FRONTEND_PORT=8080
# BACKEND_HOST_PORT=8081

# ---------------- 前端代理（Vite dev 模式）----------------
VITE_API_BASE_URL=http://localhost:8080
