# Compliance Doc Agent v1 RC
# Docker Compose 会自动读取同目录 .env；不要提交真实密钥。

# 固定演示端口（本项目只使用 19070-19079）
FRONTEND_PORT=19070
BACKEND_HOST_PORT=19071

# 零密钥默认模式。Mock 仅整理确定性工具结果，不生成风险项。
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=90

# H2 文件库由 Compose named volume 持久化。
SPRING_DATASOURCE_URL=jdbc:h2:file:/data/compliance;MODE=MySQL;DATABASE_TO_LOWER=TRUE;CASE_INSENSITIVE_IDENTIFIERS=TRUE;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# 本地脱敏演示身份。对外部署必须禁用并接入正式身份源。
DEMO_AUTH_ENABLED=true
DEMO_BCRYPT_STRENGTH=8
DEMO_USER_PASSWORD=demo-change-me
DEMO_ADMIN_PASSWORD=admin-change-me
