{
  "version": "1.0.0",
  "packName": "default",
  "description": "内置默认合规规则包：覆盖必备条款缺失、敏感词禁限、日期时效、签署位等常见合同/制度/披露审查场景",
  "rules": [
    {
      "id": "R-CON-001",
      "name": "缺失争议解决条款",
      "severity": "HIGH",
      "mode": "MISSING",
      "documentTypes": ["CONTRACT"],
      "pattern": "争议解决|仲裁|诉讼管辖|管辖法院|仲裁委员会"
    },
    {
      "id": "R-CON-002",
      "name": "缺失签署条款",
      "severity": "MEDIUM",
      "mode": "MISSING",
      "documentTypes": ["CONTRACT"],
      "pattern": "签字|签名|盖章|签署|签章"
    },
    {
      "id": "R-CON-003",
      "name": "禁止无限连带责任表述",
      "severity": "HIGH",
      "mode": "PATTERN",
      "documentTypes": ["CONTRACT", "GENERAL"],
      "pattern": "无限连带|无限责任|放弃追索|免除全部责任"
    },
    {
      "id": "R-CON-004",
      "name": "违约金比例过高",
      "severity": "HIGH",
      "mode": "PATTERN",
      "documentTypes": ["CONTRACT"],
      "pattern": "违约金.{0,30}(?:[3-9]\\d|[1-9]\\d{2,})%|超过.{0,15}30%|千分之[3-9]\\d{2,}"
    },
    {
      "id": "R-CON-005",
      "name": "缺失保密条款",
      "severity": "MEDIUM",
      "mode": "MISSING",
      "documentTypes": ["CONTRACT", "POLICY", "PRIVACY"],
      "pattern": "保密|商业秘密|机密信息|保密义务"
    },
    {
      "id": "R-DATE-001",
      "name": "合同日期逻辑异常",
      "severity": "LOW",
      "mode": "PATTERN",
      "documentTypes": ["CONTRACT", "POLICY", "GENERAL"],
      "pattern": "结束日期.{0,20}早于.{0,10}开始日期|有效期至.{0,10}已过期|已失效|终止效力"
    },
    {
      "id": "R-POL-001",
      "name": "制度缺失适用范围章节",
      "severity": "MEDIUM",
      "mode": "MISSING",
      "documentTypes": ["POLICY"],
      "pattern": "适用范围|本办法适用于|本制度适用于"
    },
    {
      "id": "R-DISC-001",
      "name": "信息披露缺失风险提示",
      "severity": "HIGH",
      "mode": "MISSING",
      "documentTypes": ["DISCLOSURE"],
      "pattern": "风险提示|风险因素|投资者需注意|重大风险"
    },
    {
      "id": "R-PII-001",
      "name": "疑似身份证号泄露",
      "severity": "MEDIUM",
      "mode": "PATTERN",
      "documentTypes": ["CONTRACT", "POLICY", "PRIVACY", "DISCLOSURE", "GENERAL"],
      "pattern": "\\d{17}[\\dXx]"
    },
    {
      "id": "R-CON-006",
      "name": "单方解除权表述",
      "severity": "HIGH",
      "mode": "PATTERN",
      "documentTypes": ["CONTRACT"],
      "pattern": "单方解除|随时解除|无需通知.{0,10}解除|任意终止"
    }
  ]
}
